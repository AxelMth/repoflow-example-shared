{
  "name": "repoflow-example-shared",
  "version": "0.2.0",
  "private": false,
  "type": "module",
  "description": "Shared Zod schemas for repoflow-example-web and repoflow-example-api",
  "author": "Axel Mathieu-Le Gall <axel@mathieu-legall.com>",
  "packageManager": "pnpm@10.33.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/axelmth/repoflow-example-shared.git"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepare": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "zod": "^3.23.8"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.19.1",
    "vitest": "^2.1.8"
  }
}
